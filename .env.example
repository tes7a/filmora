# Shared local development defaults
NODE_ENV=development

# API (apps/api)
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/filmora?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/filmora
JWT_SECRET=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRES_IN=7h
REFRESH_TOKEN_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
CLIENT_URL=http://localhost:3001

# Next.js web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Next.js admin (planned, apps/admin)
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3000/api
