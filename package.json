{
  "name": "filmora",
  "private": true,
  "scripts": {
    "build": "pnpm exec turbo run build",
    "dev": "pnpm exec turbo run dev",
    "dev:api": "pnpm exec turbo run dev --filter=./apps/api",
    "dev:web": "pnpm exec turbo run dev --filter=./apps/web",
    "dev:admin": "pnpm exec turbo run dev --filter=./apps/docs",
    "lint": "pnpm exec turbo run lint",
    "lint:fix": "pnpm exec turbo run lint -- --fix",
    "test": "pnpm exec turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "pnpm exec turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.13",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
